# .env.example — SAP FusionForge
# Run `node setup.js` to generate your .env automatically.
# Or copy this file to .env and fill in values manually.

# LLM provider (required) — anthropic | openai | azure
LLM_PROVIDER=anthropic

# LLM provider API key (required)
LLM_API_KEY=your_api_key_here

# Azure OpenAI endpoint (required only for Azure provider)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# GitHub personal access token with repo scope (required)
GITHUB_TOKEN=your_github_token_here

# Path to the local SQLite database (required)
DATABASE_PATH=./fusionforge.db

# Active client scenario (required) — matches a file in client-config/scenarios/
CLIENT_SCENARIO=hr-services

# Agent model assignments (set by setup.js or configure manually)
SOLUTION_ARCHITECT_MODEL=claude-sonnet-4-6
BUSINESS_ANALYST_MODEL=claude-sonnet-4-6
DISCOVERY_ADVISOR_MODEL=claude-sonnet-4-6
CAP_DEVELOPER_MODEL=claude-sonnet-4-6
BUILD_APPS_DEVELOPER_MODEL=claude-sonnet-4-6
BPA_DESIGNER_MODEL=claude-sonnet-4-6
BTP_ADMIN_MODEL=claude-sonnet-4-6
