# .env.example — SAP FusionForge
# Copy this file to .env and fill in your values before running setup.js

# LLM provider API key (required)
LLM_API_KEY=your_api_key_here

# GitHub personal access token with repo scope (required)
GITHUB_TOKEN=your_github_token_here

# Path to the local SQLite database (required)
DATABASE_PATH=./fusionforge.db

# Active client scenario (required) — matches a file in client-config/scenarios/
CLIENT_SCENARIO=hr-services
